# ============================================================
# Fury SMS Gateway - Environment Variables
# ============================================================

# Application
APP_NAME=fury-sms-gateway
APP_ENV=development
APP_VERSION=0.1.0

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_GRACEFUL_TIMEOUT=15s
HTTP_TRUSTED_PROXIES=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=fury
DB_PASSWORD=fury
DB_NAME=fury_sms
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
# Or use a single connection string:
# DATABASE_URL=postgres://fury:fury@localhost:5432/fury_sms?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Or use a single connection string:
# REDIS_URL=redis://:password@localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-very-long-secret-key-in-production!!!
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=720h
JWT_ISSUER=fury-sms-gateway
JWT_AUDIENCE=fury-api

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-API-Key,X-Tenant-ID
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=300

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Bootstrap (used by 'make bootstrap')
BOOTSTRAP_ADMIN_EMAIL=admin@fury-sms.com
BOOTSTRAP_ADMIN_PASSWORD=changeme1234!
BOOTSTRAP_ADMIN_NAME=Super Admin
