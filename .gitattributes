# Auto-detect text files and normalize to LF on commit
* text=auto

# Go source — always LF
*.go text eol=lf

# Shell scripts — always LF (they need LF to run on Linux)
*.sh text eol=lf

# Batch scripts — always CRLF (cmd.exe needs it)
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown, YAML, JSON, TOML, Dockerfiles — LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.ico binary
*.bin binary
*.zip binary
*.exe binary

# Makefile — LF
Makefile text eol=lf
makefile text eol=lf
